{
    "name": "misaf/laravel-email-webhooks-resend",
    "description": "Resend email webhook integration for Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "email",
        "webhook",
        "resend",
        "event",
        "integration"
    ],
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "misaf/laravel-email-webhooks": "dev-master"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-profanity": "^4.2.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "orchestra/testbench": "^11.0"
    },
    "scripts": {
        "test": "pest"
    },
    "autoload": {
        "psr-4": {
            "Misaf\\LaravelEmailWebhooksResend\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Misaf\\LaravelEmailWebhooksResend\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\LaravelEmailWebhooksResend\\EmailWebhooksResendServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
